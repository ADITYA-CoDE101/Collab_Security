# Environment variables for TCP-communication project
# Copy this file to .env and fill in the real paths.
# NEVER commit your .env file! might got yourself into trubble lol

# --- Server ---
HOST=
PORT=

# --- Database ---
DB_HOST=
DB_USER=
DB_PASSWORD=
DATABASE_NAME=

# --- TLS (Server side) ---
SSL_CERT_PATH=certs/server-cert.pem         # The server's own certificate and private key
SSL_KEY_PATH=certs/server-key.pem

SSL_CA_PATH=certs/ca-cert.pem               # The CA certificate used to verify connecting clients (mTLS)

# --- TLS (Client side) ---

SSL_CLIENT_CERT_PATH=certs/client-cert.pem  # The client's own certificate and private key
SSL_CLIENT_KEY_PATH=certs/client-key.pem
# (Clients also use SSL_CA_PATH above to verify the server)
